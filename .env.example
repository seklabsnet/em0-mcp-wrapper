# em0 MCP Wrapper Configuration
# Copy this file as .env and fill in the values

# REQUIRED: mem0 server URL (Azure Container App)
MEM0_API_URL=https://mem0-server.happygrass-15b6b68c.westeurope.azurecontainerapps.io

# REQUIRED: mem0 API key
MEM0_API_KEY=your-api-key-here

# OPTIONAL: Default user ID (defaults to "centauri")
MEM0_USER_ID=centauri

# OPTIONAL: Request timeout in seconds (default: 30)
MEM0_TIMEOUT=30
